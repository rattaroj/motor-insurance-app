{
  "ConnectionStrings": {
    "Default": "Server=localhost;Database=MotorInsurance;Trusted_Connection=True;TrustServerCertificate=True"
  },
  "Jwt": {
    "Issuer": "MotorInsurance",
    "Audience": "MotorInsuranceClient",
    "SigningKey": "dev-only-signing-key-change-me-please-32+chars-long-secret",
    "AccessTokenMinutes": 15,
    "RefreshTokenDays": 7
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "PromptPay": {
    "Target": "0812345678",
    "WebhookSecret": ""
  },
  "Notifications": {
    "Channel": "Log",
    "Smtp": {
      "Host": "localhost",
      "Port": 25,
      "User": "",
      "Password": "",
      "From": "noreply@motor.local",
      "UseSsl": false
    },
    "Line": {
      "Token": ""
    }
  },
  "PolicyLifecycle": {
    "Enabled": true,
    "AutoExpire": true,
    "AutoRemind": true,
    "AutoWeeklyDigest": true,
    "DigestDayOfWeek": "Monday",
    "RunIntervalHours": 6,
    "ReminderWindowDays": 60,
    "ReminderThrottleDays": 7
  },
  "AllowedHosts": "*"
}